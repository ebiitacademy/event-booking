# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: paid bookings use create_booking_for_stripe (service role); never expose in client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (no trailing slash) — used for Stripe success/cancel redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Dashboard → Developers → API keys) — no webhooks required for this app
STRIPE_SECRET_KEY=sk_test_...
